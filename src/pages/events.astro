---
import MainLayout from "@/layouts/MainLayout.astro";
import { Calendar, type CalendarEventItem } from "@/components/events/calendar";
import { PageHeader } from "@/components/PageHeader";
import { getCollection, setContentCacheHeaders } from "@/lib/content";

const [events, venues] = await Promise.all([
  getCollection("events"),
  getCollection("venues"),
]);

// Reference fields store raw entry ids — join venues manually.
const venueTitleById = new Map(
  venues.map((venue) => [venue.id, venue.data.title]),
);

const calendarEvents: CalendarEventItem[] = events.map((event) => ({
  id: event.id,
  name: event.data.name,
  event_start: event.data.event_start,
  event_end: event.data.event_end,
  location: event.data.location,
  venueTitle: (event.data.venue && venueTitleById.get(event.data.venue)) || "",
  description: event.data.description ?? [],
}));

setContentCacheHeaders(Astro);
---

<MainLayout title="Events" description="Event Calendar">
  <div class="mt-6 flex w-full items-center justify-center lg:mt-9">
    <div class="container h-fit w-full max-w-4xl px-0 md:px-8">
      <PageHeader>Event Schedule</PageHeader>
      <Calendar
        events={calendarEvents}
        params={Object.fromEntries(Astro.url.searchParams.entries())}
        client:load
      />
    </div>
  </div>
</MainLayout>
