---
import { PageHeader } from "@/components/PageHeader";
import MainLayout from "@/layouts/MainLayout.astro";
import { bySort, getCollection, setContentCacheHeaders } from "@/lib/content";
import slugify from "@sindresorhus/slugify";
import { Image as MediaImage } from "emdash/ui";

const people = (await getCollection("people")).sort(bySort);

setContentCacheHeaders(Astro);
---

<MainLayout title="Educators" description="Educators">
  <div class="container max-w-4xl">
    <PageHeader>Educators and Presentors</PageHeader>
    <p class="my-6">
      We'd like to recognize and thank the following educators and presentors
      who are volunteering their time this year.
    </p>
    <ul class="mt-4 flex flex-col gap-4">
      {
        people.map((person) => (
          <li id={slugify(person.data.display_name)}>
            <div>
              <MediaImage
                image={person.data.profile_pic}
                width={480}
                alt={person.data.display_name}
                class="float-left mb-2 mr-8 mt-4 max-w-[min(25vw,15rem)] rounded-2xl border-2 border-primary shadow-[1rem_-1rem_0_0_var(--tw-shadow)] shadow-alternate"
              />
              <h2 class="text-2xl font-bold">{person.data.display_name}</h2>
              <hr class="my-4 h-[2px] bg-white" />
              <span class="prose-base">{person.data.bio}</span>
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</MainLayout>
