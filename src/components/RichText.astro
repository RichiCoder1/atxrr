---
/**
 * Site-wide Portable Text renderer; styling comes from a surrounding `prose`.
 *
 * `htmlBlock` nodes carry raw HTML migrated from Directus. EmDash sanitises
 * them, but treat the content as trusted-admin-only regardless.
 */
import type { PortableTextBlock } from "emdash";
import { PortableText } from "emdash/ui";

interface Props {
	value: PortableTextBlock[] | undefined | null;
}

const { value } = Astro.props;
---

{value && value.length > 0 && <PortableText value={value} />}
